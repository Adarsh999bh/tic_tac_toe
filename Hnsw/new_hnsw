use std::fs::create_dir_all;
use std::path::{Path, PathBuf};
use std::sync::atomic::AtomicBool;
use std::sync::Arc;

use atomic_refcell::AtomicRefCell;
use common::cpu::CpuPermit;
use common::types::{PointOffsetType, ScoredPointOffset, TelemetryDetail};
use log::debug;
use rand::thread_rng;

use crate::common::operation_error::{check_process_stopped, OperationError, OperationResult};
use crate::data_types::vectors::{QueryVector, VectorRef};
use crate::id_tracker::{IdTracker, IdTrackerSS};
use crate::index::hnsw_index::config::HnswGraphConfig;
use crate::index::hnsw_index::graph_layers::GraphLayers;
use crate::index::hnsw_index::graph_layers_builder::GraphLayersBuilder;
use crate::index::hnsw_index::graph_links::{GraphLinks, GraphLinksRam};
use crate::index::hnsw_index::hnsw::{HNSWIndex, HNSW_USE_HEURISTIC};
use crate::index::hnsw_index::point_scorer::FilteredScorer;
use crate::index::struct_payload_index::StructPayloadIndex;
use crate::index::VectorIndex;
use crate::telemetry::VectorIndexSearchesTelemetry;
use crate::types::{Filter, SearchParams};
use crate::vector_storage::quantized::quantized_vectors::QuantizedVectors;
use crate::vector_storage::{new_raw_scorer, VectorStorage, VectorStorageEnum};

pub const INCREMENTAL_BUILDER_STATE_FILE: &str = "incremental_builder.bin";

/// Threshold: when the number of pending incremental changes exceeds this
/// fraction of the total indexed points, trigger a full rebuild.
const REBUILD_FRACTION_THRESHOLD: f64 = 0.3;

/// IncrementalHnswIndex wraps an HNSWIndex and maintains a mutable
/// GraphLayersBuilder to support incremental point insertion and removal
/// without requiring a full graph rebuild for every change.
///
/// Architecture:
/// - The underlying `HNSWIndex` holds the immutable base graph for efficient search
/// - A `GraphLayersBuilder` (the "incremental builder") tracks points added/removed
///   since the last full build
/// - On search, we query the base graph (new points added incrementally are
///   visible after the next compaction)
/// - When the number of incremental changes exceeds a threshold, we trigger
///   a full rebuild that incorporates all changes
///
/// This enables O(log n) point insertions instead of O(n log n) full rebuilds.
pub struct IncrementalHnswIndex<TGraphLinks: GraphLinks> {
    /// The underlying HNSW index (immutable base graph + search)
    base_index: HNSWIndex<TGraphLinks>,

    /// Mutable builder for incremental operations. `None` until the first
    /// incremental operation or until loaded from a saved state.
    incremental_builder: Option<GraphLayersBuilder>,

    /// Number of incremental additions since last full build
    additions_since_rebuild: usize,

    /// Number of incremental removals since last full build
    removals_since_rebuild: usize,

    /// Points that have been removed since last rebuild.
    /// These are filtered out during search.
    removed_points: Vec<PointOffsetType>,

    /// Path for persisting the incremental builder state
    path: PathBuf,
}

impl<TGraphLinks: GraphLinks> IncrementalHnswIndex<TGraphLinks> {
    /// Open or create an IncrementalHnswIndex.
    pub fn open(
        path: &Path,
        id_tracker: Arc<AtomicRefCell<IdTrackerSS>>,
        vector_storage: Arc<AtomicRefCell<VectorStorageEnum>>,
        quantized_vectors: Arc<AtomicRefCell<Option<QuantizedVectors>>>,
        payload_index: Arc<AtomicRefCell<StructPayloadIndex>>,
        hnsw_config: crate::types::HnswConfig,
    ) -> OperationResult<Self> {
        create_dir_all(path)?;

        let base_index = HNSWIndex::open(
            path,
            id_tracker,
            vector_storage,
            quantized_vectors,
            payload_index,
            hnsw_config,
        )?;

        // Try to load incremental builder state
        let builder_path = Self::builder_state_path(path);
        let incremental_builder = if builder_path.exists() {
            match GraphLayersBuilder::load_state(&builder_path) {
                Ok(builder) => {
                    debug!("Loaded incremental HNSW builder state from {:?}", builder_path);
                    Some(builder)
                }
                Err(e) => {
                    debug!("Failed to load incremental builder state: {}, starting fresh", e);
                    None
                }
            }
        } else {
            None
        };

        Ok(Self {
            base_index,
            incremental_builder,
            additions_since_rebuild: 0,
            removals_since_rebuild: 0,
            removed_points: Vec::new(),
            path: path.to_owned(),
        })
    }

    fn builder_state_path(path: &Path) -> PathBuf {
        path.join(INCREMENTAL_BUILDER_STATE_FILE)
    }

    /// Initialize the incremental builder from the base index if not already present.
    fn ensure_builder(&mut self) -> &mut GraphLayersBuilder {
        if self.incremental_builder.is_none() {
            let config = self.base_index.config();
            let vector_storage = self.base_index.vector_storage();
            let total = vector_storage.borrow().total_vector_count();

            let builder = GraphLayersBuilder::new(
                total,
                config.m,
                config.m0,
                config.ef_construct,
                1, // entry_points_num
                HNSW_USE_HEURISTIC,
            );
            self.incremental_builder = Some(builder);
        }
        self.incremental_builder.as_mut().unwrap()
    }

    /// Check if we should do a full rebuild based on the number of changes.
    fn should_rebuild(&self) -> bool {
        let total_indexed = self.base_index.indexed_vector_count();
        if total_indexed == 0 {
            return self.additions_since_rebuild > 0;
        }
        let total_changes = self.additions_since_rebuild + self.removals_since_rebuild;
        (total_changes as f64 / total_indexed as f64) > REBUILD_FRACTION_THRESHOLD
    }

    /// Add a single point incrementally to the HNSW graph.
    pub fn add_point(
        &mut self,
        point_id: PointOffsetType,
        stopped: &AtomicBool,
    ) -> OperationResult<()> {
        check_process_stopped(stopped)?;

        // Ensure builder exists first (needs &mut self)
        self.ensure_builder();

        // Clone Arcs so we don't hold a borrow on self
        let vector_storage = self.base_index.vector_storage().clone();
        let id_tracker = self.base_index.id_tracker().clone();
        let quantized_vectors = self.base_index.get_quantized_vectors();

        let vs_borrow = vector_storage.borrow();
        let id_t_borrow = id_tracker.borrow();
        let qv_borrow = quantized_vectors.borrow();

        let vector = vs_borrow.get_vector(point_id);
        let vector = vector.as_vec_ref().into();

        let raw_scorer = if let Some(quantized_storage) = qv_borrow.as_ref() {
            quantized_storage.raw_scorer(
                vector,
                id_t_borrow.deleted_point_bitslice(),
                vs_borrow.deleted_vector_bitslice(),
                stopped,
            )
        } else {
            new_raw_scorer(vector, &vs_borrow, id_t_borrow.deleted_point_bitslice())
        }?;

        let points_scorer = FilteredScorer::new(raw_scorer.as_ref(), None);

        let mut rng = thread_rng();
        let builder = self.incremental_builder.as_mut().unwrap();
        let level = builder.get_random_layer(&mut rng);
        builder.add_new_point(point_id, level, points_scorer);

        self.additions_since_rebuild += 1;

        // Remove from removed list if it was previously removed
        self.removed_points.retain(|&p| p != point_id);

        Ok(())
    }

    /// Remove a single point from the HNSW graph incrementally.
    pub fn remove_point(&mut self, point_id: PointOffsetType) -> OperationResult<()> {
        if let Some(builder) = &mut self.incremental_builder {
            builder.remove_point(point_id);
        }

        if !self.removed_points.contains(&point_id) {
            self.removed_points.push(point_id);
        }

        self.removals_since_rebuild += 1;
        Ok(())
    }

    /// Save the current incremental builder state to disk.
    pub fn save_incremental_state(&self) -> OperationResult<()> {
        if let Some(builder) = &self.incremental_builder {
            let state_path = Self::builder_state_path(&self.path);
            builder.save_state(&state_path)?;
            debug!("Saved incremental HNSW builder state to {:?}", state_path);
        }
        Ok(())
    }

    /// Get the total number of indexed points (base + incremental additions - removals).
    pub fn total_indexed_count(&self) -> usize {
        let base = self.base_index.indexed_vector_count();
        base + self.additions_since_rebuild - self.removals_since_rebuild.min(base)
    }

    /// Get the number of pending incremental changes.
    pub fn pending_changes(&self) -> usize {
        self.additions_since_rebuild + self.removals_since_rebuild
    }

    /// Access the underlying base index.
    pub fn base_index(&self) -> &HNSWIndex<TGraphLinks> {
        &self.base_index
    }

    /// Access the underlying base index mutably (for full rebuild).
    pub fn base_index_mut(&mut self) -> &mut HNSWIndex<TGraphLinks> {
        &mut self.base_index
    }

    /// Perform a full rebuild, incorporating all incremental changes.
    /// After rebuild, the incremental builder is cleared.
    pub fn full_rebuild(
        &mut self,
        permit: Arc<CpuPermit>,
        stopped: &AtomicBool,
    ) -> OperationResult<()> {
        debug!(
            "Performing full HNSW rebuild ({} additions, {} removals pending)",
            self.additions_since_rebuild, self.removals_since_rebuild
        );

        self.base_index.build_index(permit, stopped)?;

        // Clear incremental state
        self.incremental_builder = None;
        self.additions_since_rebuild = 0;
        self.removals_since_rebuild = 0;
        self.removed_points.clear();

        // Remove saved state file
        let state_path = Self::builder_state_path(&self.path);
        if state_path.exists() {
            std::fs::remove_file(&state_path).ok();
        }

        Ok(())
    }

    /// Build the index, either incrementally or full depending on the state.
    pub fn build_index_incremental(
        &mut self,
        permit: Arc<CpuPermit>,
        stopped: &AtomicBool,
    ) -> OperationResult<()> {
        if self.should_rebuild() || self.base_index.indexed_vector_count() == 0 {
            self.full_rebuild(permit, stopped)
        } else {
            // Save incremental state only
            self.save_incremental_state()
        }
    }
}

impl<TGraphLinks: GraphLinks> VectorIndex for IncrementalHnswIndex<TGraphLinks> {
    fn search(
        &self,
        vectors: &[&QueryVector],
        filter: Option<&Filter>,
        top: usize,
        params: Option<&SearchParams>,
        is_stopped: &AtomicBool,
    ) -> OperationResult<Vec<Vec<ScoredPointOffset>>> {
        // Delegate to base index search - removed points are already handled
        // by the id_tracker's deleted bitslice
        self.base_index.search(vectors, filter, top, params, is_stopped)
    }

    fn build_index(
        &mut self,
        permit: Arc<CpuPermit>,
        stopped: &AtomicBool,
    ) -> OperationResult<()> {
        self.build_index_incremental(permit, stopped)
    }

    fn get_telemetry_data(&self, detail: TelemetryDetail) -> VectorIndexSearchesTelemetry {
        self.base_index.get_telemetry_data(detail)
    }

    fn files(&self) -> Vec<PathBuf> {
        let mut files = self.base_index.files();
        let state_path = Self::builder_state_path(&self.path);
        if state_path.exists() {
            files.push(state_path);
        }
        files
    }

    fn indexed_vector_count(&self) -> usize {
        self.total_indexed_count()
    }

    fn update_vector(
        &mut self,
        id: PointOffsetType,
        _vector: VectorRef,
    ) -> OperationResult<()> {
        // For HNSW, updating a vector means removing the old point and
        // re-inserting with the new vector. The vector storage is already
        // updated by the caller, so we just need to re-link in the graph.
        let stopped = AtomicBool::new(false);

        // Remove old links
        self.remove_point(id)?;

        // Re-insert with updated vector
        self.add_point(id, &stopped)?;

        Ok(())
    }
}
