use std::ops::Range;
use std::path::Path;

use common::types::PointOffsetType;
use serde::{Deserialize, Serialize};

use crate::common::operation_error::OperationResult;
use crate::index::hnsw_index::graph_layers::LayersContainer;
use crate::index::hnsw_index::graph_links::{GraphLinks, GraphLinksConverter};

/// Mutable graph links implementation that supports incremental point
/// addition and removal. Unlike `GraphLinksRam`/`GraphLinksMmap` which are
/// immutable after construction, this stores links in a `Vec<Vec<Vec<PointOffsetType>>>`
/// structure that can be modified in place.
///
/// The trade-off is higher memory usage and slower link access compared to
/// the compacted immutable format, but it enables O(1) per-point mutations.
#[derive(Default, Clone, Debug, Serialize, Deserialize)]
pub struct GraphLinksMut {
    /// links_layers[point_id][level] = Vec<neighbor_point_ids>
    links_layers: Vec<LayersContainer>,
}

impl GraphLinksMut {
    /// Create a new mutable graph links structure with a given number of points.
    /// All points start with a single empty level-0 link list.
    pub fn new(num_points: usize) -> Self {
        let links_layers = (0..num_points)
            .map(|_| vec![Vec::new()])
            .collect();
        Self { links_layers }
    }

    /// Build from an existing layers container (e.g. from GraphLayersBuilder).
    pub fn from_layers(links_layers: Vec<LayersContainer>) -> Self {
        Self { links_layers }
    }

    /// Number of points in the graph.
    pub fn num_points_mut(&self) -> usize {
        self.links_layers.len()
    }

    /// Ensure the structure has at least `num_points` slots.
    pub fn ensure_capacity(&mut self, num_points: usize) {
        while self.links_layers.len() < num_points {
            self.links_layers.push(vec![Vec::new()]);
        }
    }

    /// Set levels for a point, allocating empty link lists as needed.
    pub fn set_levels(&mut self, point_id: PointOffsetType, level: usize) {
        let pid = point_id as usize;
        self.ensure_capacity(pid + 1);
        let point_layers = &mut self.links_layers[pid];
        while point_layers.len() <= level {
            point_layers.push(Vec::new());
        }
    }

    /// Get the level of a point.
    pub fn point_level_mut(&self, point_id: PointOffsetType) -> usize {
        let pid = point_id as usize;
        if pid < self.links_layers.len() && !self.links_layers[pid].is_empty() {
            self.links_layers[pid].len() - 1
        } else {
            0
        }
    }

    /// Get mutable access to a point's links at a given level.
    pub fn links_mut(
        &mut self,
        point_id: PointOffsetType,
        level: usize,
    ) -> &mut Vec<PointOffsetType> {
        &mut self.links_layers[point_id as usize][level]
    }

    /// Get read access to a point's links at a given level.
    pub fn links_ref(&self, point_id: PointOffsetType, level: usize) -> &[PointOffsetType] {
        let pid = point_id as usize;
        if pid < self.links_layers.len() && level < self.links_layers[pid].len() {
            &self.links_layers[pid][level]
        } else {
            &[]
        }
    }

    /// Remove all links to/from a point. This clears the point's own link lists
    /// and removes the point from all neighbor link lists.
    pub fn remove_point(&mut self, point_id: PointOffsetType) {
        let pid = point_id as usize;
        if pid >= self.links_layers.len() {
            return;
        }

        // Collect neighbors across all levels so we can remove back-links
        let num_levels = self.links_layers[pid].len();
        let mut neighbors_by_level: Vec<Vec<PointOffsetType>> = Vec::with_capacity(num_levels);
        for level in 0..num_levels {
            neighbors_by_level.push(self.links_layers[pid][level].clone());
        }

        // Clear this point's own links
        for level in 0..num_levels {
            self.links_layers[pid][level].clear();
        }

        // Remove back-links from all neighbors
        for (level, neighbors) in neighbors_by_level.iter().enumerate() {
            for &neighbor_id in neighbors {
                let nid = neighbor_id as usize;
                if nid < self.links_layers.len() && level < self.links_layers[nid].len() {
                    self.links_layers[nid][level].retain(|&x| x != point_id);
                }
            }
        }
    }

    /// Add a bidirectional link between two points at a given level.
    pub fn add_link(
        &mut self,
        point_a: PointOffsetType,
        point_b: PointOffsetType,
        level: usize,
    ) {
        let a = point_a as usize;
        let b = point_b as usize;

        if a < self.links_layers.len()
            && level < self.links_layers[a].len()
            && !self.links_layers[a][level].contains(&point_b)
        {
            self.links_layers[a][level].push(point_b);
        }

        if b < self.links_layers.len()
            && level < self.links_layers[b].len()
            && !self.links_layers[b][level].contains(&point_a)
        {
            self.links_layers[b][level].push(point_a);
        }
    }

    /// Convert to a `GraphLinksConverter` for serialization or conversion to
    /// immutable `GraphLinks`.
    pub fn into_converter(self) -> GraphLinksConverter {
        GraphLinksConverter::new(self.links_layers)
    }

    /// Convert into an immutable `GraphLinks` implementation.
    pub fn into_graph_links<TGraphLinks: GraphLinks>(
        self,
        path: Option<&Path>,
    ) -> OperationResult<TGraphLinks> {
        let mut converter = self.into_converter();
        if let Some(path) = path {
            converter.save_as(path)?;
        }
        TGraphLinks::from_converter(converter)
    }

    /// Get the underlying layers for read access.
    pub fn layers(&self) -> &Vec<LayersContainer> {
        &self.links_layers
    }
}
