#[derive(Serialize, Deserialize)]
pub struct GraphLayersBuilderState {
    pub max_level: usize,
    pub m: usize,
    pub m0: usize,
    pub ef_construct: usize,
    pub level_factor: f64,
    pub use_heuristic: bool,
    pub links_layers: Vec<Vec<Vec<PointOffsetType>>>,
    pub entry_points: EntryPoints,
    pub ready_list: Vec<bool>,
}

impl GraphLayersBuilder {
    pub fn save_state(&self, path: &Path) -> OperationResult<()> {
        let links: Vec<Vec<Vec<PointOffsetType>>> = self
            .links_layers
            .iter()
            .map(|layers| layers.iter().map(|l| l.read().clone()).collect())
            .collect();
        let ready: Vec<bool> = {
            let r = self.ready_list.read();
            r.iter().map(|b| *b).collect()
        };
        let state = GraphLayersBuilderState {
            max_level: self.max_level.load(std::sync::atomic::Ordering::Relaxed),
            m: self.m,
            m0: self.m0,
            ef_construct: self.ef_construct,
            level_factor: self.level_factor,
            use_heuristic: self.use_heuristic,
            links_layers: links,
            entry_points: self.entry_points.lock().clone(),
            ready_list: ready,
        };
        Ok(atomic_save_bin(path, &state)?)
    }

    pub fn load_state(path: &Path) -> OperationResult<Self> {
        let state: GraphLayersBuilderState = read_bin(path)?;
        let links_layers: Vec<LockedLayersContainer> = state
            .links_layers
            .into_iter()
            .map(|layers| layers.into_iter().map(|l| RwLock::new(l)).collect())
            .collect();
        let ready_bits: BitVec = state.ready_list.into_iter().collect();
        Ok(Self {
            max_level: AtomicUsize::new(state.max_level),
            m: state.m,
            m0: state.m0,
            ef_construct: state.ef_construct,
            level_factor: state.level_factor,
            use_heuristic: state.use_heuristic,
            links_layers,
            entry_points: Mutex::new(state.entry_points),
            visited_pool: VisitedPool::new(),
            ready_list: RwLock::new(ready_bits),
        })
    }
}
