    // ---- Incremental indexing methods ----

    pub fn ensure_point_capacity(&self, point_id: PointOffsetType) -> bool {
        false
    }

    pub fn expand_to_fit(&mut self, new_size: usize) {
        while self.links_layers.len() < new_size {
            self.links_layers.push(vec![RwLock::new(Vec::with_capacity(self.m0))]);
        }
        let mut ready = self.ready_list.write();
        ready.resize(new_size, false);
    }

    pub fn add_new_point(
        &mut self,
        point_id: PointOffsetType,
        level: usize,
        points_scorer: FilteredScorer,
    ) {
        let pid = point_id as usize;
        self.expand_to_fit(pid + 1);
        self.set_levels(point_id, level);
        self.link_new_point(point_id, points_scorer);
    }

    pub fn remove_point(&mut self, point_id: PointOffsetType) {
        let pid = point_id as usize;
        if pid >= self.links_layers.len() {
            return;
        }
        let num_levels = self.links_layers[pid].len();
        let mut neighbors_by_level: Vec<Vec<PointOffsetType>> = Vec::with_capacity(num_levels);
        for level in 0..num_levels {
            let links = self.links_layers[pid][level].read();
            neighbors_by_level.push(links.clone());
        }
        for level in 0..num_levels {
            self.links_layers[pid][level].write().clear();
        }
        for (level, neighbors) in neighbors_by_level.iter().enumerate() {
            for &neighbor_id in neighbors {
                let nid = neighbor_id as usize;
                if nid < self.links_layers.len() && level < self.links_layers[nid].len() {
                    let mut neighbor_links = self.links_layers[nid][level].write();
                    neighbor_links.retain(|&x| x != point_id);
                }
            }
        }
        self.ready_list.write().set(pid, false);
        {
            let mut entry_points = self.entry_points.lock();
            entry_points.remove_point(point_id);
        }
    }

